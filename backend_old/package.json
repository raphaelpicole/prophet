    "fastify": "^4.28.0",
    "fastify-cors": "^6.1.0",
    "ioredis": "^5.4.1",
    "openai": "^4.52.0",
    "pg": "^8.12.0",
    "pino": "^9.3.0",
    "pino-pretty": "^11.2.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/axios": "^0.9.36",
    "@types/cors": "^2.8.17",
    "@types/node": "^20.14.0",
