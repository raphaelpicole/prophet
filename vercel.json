{
  "version": 2,
  "project": "workspace",
  "installCommand": "cd server && npm install",
  "buildCommand": "bash build-frontend.sh",
  "outputDirectory": "app/build/web",
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" }
  ],
  "crons": [{
    "path": "/api/cron/collect",
    "schedule": "0 11 * * *"
  }]
}
