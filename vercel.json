{
  "version": 2,
  "installCommand": "cd server && npm install",
  "buildCommand": "cd server && npm run build",
  "outputDirectory": "app/build/web",
  "routes": [
    { "src": "/api/cron/collect", "dest": "server/dist/api/cron/collect.js" },
    { "src": "/api/cron/maintenance", "dest": "server/dist/api/cron/maintenance.js" },
    { "src": "/api/collect", "dest": "server/dist/api/collect.js" },
    { "src": "/api/regions", "dest": "server/dist/api/regions.js" },
    { "src": "/api/sources", "dest": "server/dist/api/sources.js" },
    { "src": "/api/indicators", "dest": "server/dist/api/indicators.js" },
    { "src": "/api/stories", "dest": "server/dist/api/stories.js" },
    { "src": "/api/story", "dest": "server/dist/api/story.js" },
    { "src": "/api/(.*)", "dest": "server/dist/api/$1.js" }
  ],
  "crons": [{
    "path": "/api/cron/collect",
    "schedule": "0 11 * * *"
  }, {
    "path": "/api/cron/maintenance",
    "schedule": "0 10 * * 0"
  }]
}
