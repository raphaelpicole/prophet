{
  "version": 2,
  "installCommand": "cd server && npm install",
  "buildCommand": "cd server && npm run build",
  "outputDirectory": "app/build/web",
  "functions": {
    "api/collect.js": {
      "maxDuration": 300
    },
    "api/stories.js": {
      "maxDuration": 30
    },
    "api/sources.js": {
      "maxDuration": 10
    },
    "api/indicators.js": {
      "maxDuration": 10
    },
    "api/story.js": {
      "maxDuration": 10
    }
  },
  "routes": [
    { "src": "/api/cron/collect", "dest": "api/collect.js" },
    { "src": "/api/stories", "dest": "api/stories.js" },
    { "src": "/api/sources", "dest": "api/sources.js" },
    { "src": "/api/indicators", "dest": "api/indicators.js" },
    { "src": "/api/story", "dest": "api/story.js" }
  ],
  "crons": [{
    "path": "/api/cron/collect",
    "schedule": "0 11 * * *"
  }]
}
