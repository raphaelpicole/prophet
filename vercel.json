{
  "version": 2,
  "installCommand": "cd server && npm install",
  "buildCommand": "echo 'Using prebuilt server files'",
  "outputDirectory": "app/build/web",
  "functions": {
    "api/index.js": {
      "maxDuration": 30
    }
  },
  "routes": [
    { "src": "/api/sources", "dest": "api/index.js" },
    { "src": "/api/stories", "dest": "api/index.js" },
    { "src": "/api/story", "dest": "api/index.js" },
    { "src": "/api/indicators", "dest": "api/index.js" },
    { "src": "/api/collect", "dest": "api/index.js" },
    { "src": "/api/cron/collect", "dest": "api/index.js" },
    { "src": "/api/(.*)", "dest": "api/index.js" }
  ],
  "crons": [{
    "path": "/api/cron/collect",
    "schedule": "0 11 * * *"
  }]
}
