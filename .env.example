# ─── Prophet — Environment Variables ───────────────────────────────────────────
# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local to version control.

# ── Supabase ──────────────────────────────────────────────────────────────────
# Required. Get from Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-or-service-role-key

# ── Ollama Cloud / LLM Providers ──────────────────────────────────────────────
# Required for AI analysis. Get from https://ollama.cloud or use local Ollama
OLLAMA_API_KEY=your-ollama-cloud-api-key
OLLAMA_CLOUD_MODEL=gemma4:31b

# Optional: Groq API key for faster inference (https://console.groq.com)
GROQ_API_KEY=your-groq-api-key

# Optional: Sentry DSN for error tracking (https://sentry.io)
SENTRY_DSN=https://your-sentry-dsn.ingest.sentry.io/project-id

# ── Vercel (auto-set by Vercel CLI / platform) ─────────────────────────────────
VERCEL_ENV=development
VERCEL_URL=localhost:3000
