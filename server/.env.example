# Prophet Server - Environment Variables
# Copie este arquivo para .env e preencha com seus valores

# ============================================
# SUPABASE (Obrigatório)
# ============================================
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# Para migrações (service role key):
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================
# LLM APIs (Opcional - usar mock se não configurado)
# ============================================

# Groq (Recomendado - rápido e gratuito) - https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# GLM (Zhipu AI) - https://open.bigmodel.cn
GLM_API_KEY=

# Qwen (Silicon Flow) - https://siliconflow.cn
QWEN_API_KEY=

# OpenAI/DeepSeek compatível
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-3.5-turbo

# Ollama (local)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ============================================
# Coletores (Opcional - usar padrões se não configurado)
# ============================================
# User-Agent para requisições HTTP
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36

# Proxy (se necessário para sites protegidos)
# HTTP_PROXY=http://proxy:8080
# HTTPS_PROXY=http://proxy:8080

# ============================================
# Configurações do Pipeline
# ============================================
# Intervalo entre requisições (ms)
REQUEST_DELAY=100

# Limite de notícias por fonte por execução
MAX_ARTICLES_PER_SOURCE=50

# Timeout para requisições (ms)
FETCH_TIMEOUT=10000
